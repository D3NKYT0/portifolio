# ──────────────────────────────────────────────────────────────────────────────
# Denky Portfolio — raiz: frontend (Vite) + Docker Compose
# ──────────────────────────────────────────────────────────────────────────────
# Copie para `.env` na raiz.
# backend/.env — Django (SECRET_KEY, DB, e-mail)

# Frontend (build Vite) — same-origin, sem subdomínio de API
VITE_API_URL=/api/v1
VITE_FRONTEND_URL=https://denky.dev.br

# Docker Compose
# Dev local:  COMPOSE_PROFILES=dev  + FRONTEND_SERVE_MODE=dev
# Produção:   COMPOSE_PROFILES=static + FRONTEND_SERVE_MODE=static
COMPOSE_PROFILES=dev
FRONTEND_SERVE_MODE=dev
