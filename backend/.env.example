SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=denky.dev.br,www.denky.dev.br,localhost,127.0.0.1,backend

DB_NAME=denky
DB_USER=denky
DB_PASSWORD=troque-esta-senha
DB_HOST=db
DB_PORT=5432

# Same-origin em produção (/api/v1) — CORS só importa para admin ou integrações externas
CORS_ALLOWED_ORIGINS=https://denky.dev.br,https://www.denky.dev.br,http://localhost,http://127.0.0.1
CSRF_TRUSTED_ORIGINS=https://denky.dev.br,https://www.denky.dev.br,http://localhost,http://127.0.0.1
CONTACT_EMAIL=contato@denky.dev.br

# Cookies seguros quando DEBUG=False (HTTPS via Cloudflare/Nginx)
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
